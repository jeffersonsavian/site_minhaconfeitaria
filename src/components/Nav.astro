---
import { Image } from 'astro:assets';
import logoNav from '../assets/logo-nav.png';
---

<nav id="nav">
  <div class="nav-in">
    <a href="/" class="nav-logo"><Image src={logoNav} alt="Minha Confeitaria App" width={137} height={100} densities={[2]} format="webp" loading="eager" /></a>
    <ul class="nav-links">
      <li><a href="/funcionalidades">Funcionalidades</a></li>
      <li><a href="/precos">Preços</a></li>
      <li><a href="/#faq">FAQ</a></li>
      <li><a href="/contato">Contato</a></li>
    </ul>
    <div class="nav-ctas">
      <a href="https://app.minhaconfeitaria.com/login" class="nav-login">Entrar</a>
      <a href="https://app.minhaconfeitaria.com" class="nav-cta">Testar Grátis</a>
    </div>
  </div>
</nav>

<script>
// NAV SCROLL
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('sc', scrollY > 40));
</script>
