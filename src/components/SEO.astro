---
/**
 * Componente: SEO (minhaconfeitaria)
 *
 * Wrapper local que mantém charset/viewport/favicon e preload de fonte,
 * e delega o SEO em si (title/description/canonical/og/twitter) para
 * o componente web-kit Seo.astro.
 */

import Seo from 'web-kit/components/Seo.astro';
import type { SeoConfig } from 'web-kit/config';

interface Props {
  title: string;
  description: string;
  canonical: string;
  image?: string;
  noindex?: boolean;
  config?: SeoConfig;
}

const { title, description, canonical, image, noindex, config } = Astro.props;
---

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Favicon -->
<link rel="icon" href="/images/logo-mini.png">

<!-- Fonts (self-hosted) — preload da fonte do corpo p/ tirar do caminho crítico -->
<link rel="preload" href="/fonts/plus-jakarta-sans-var.woff2" as="font" type="font/woff2" crossorigin>

<!-- SEO compartilhado (web-kit) -->
<Seo
  title={title}
  description={description}
  canonical={canonical}
  image={image}
  noindex={noindex}
  config={config}
/>
