---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Preços — Minha Confeitaria App" description="Planos do Minha Confeitaria App para todos os tamanhos de confeitaria. Comece grátis e fature mais com preços justos e sem surpresas." canonical="/precos">
<div class="page-hero">
  <div class="page-hero-glow"></div>
  <div class="container" style="position:relative;z-index:2">
    <div class="hero-breadcrumb"><a href="/">Home</a> <span>/</span> <span>Preços</span></div>
    <div class="tag" style="background:rgba(245,197,0,.15);color:var(--yellow)">Preços</div>
    <h1>Você no controle<br>do seu negócio</h1>
    <p>Não precisa de cartão de crédito. Comece grátis e faça upgrade quando quiser crescer mais.</p>
  </div>
</div>

<section class="section" id="planos">
  <div class="container">
    <div class="pricing-grid">
      <div class="plan reveal">
        <div class="plan-cat">Plano Gratuito</div>
        <div class="plan-sub">Todos têm o direito de empreender</div>
        <div class="plan-price-row"><span class="p-free">Grátis</span></div>
        <div class="plan-per">para sempre · sem cartão de crédito</div>
        <div class="plan-div"></div>
        <ul class="plan-feats">
          <li><span class="ck-y">✓</span> Cadastro de Ingredientes</li>
          <li><span class="ck-y">✓</span> Cadastro de Receitas</li>
          <li><span class="ck-y">✓</span> Gerador de Orçamento</li>
          <li><span class="ck-y">✓</span> Backups Diários</li>
          <li><span class="ck-y">✓</span> 1 Usuário</li>
          <li><span class="ck-n">—</span> Gerenciamento de Pedidos</li>
          <li><span class="ck-n">—</span> Cadastro de Clientes</li>
          <li><span class="ck-n">—</span> Fluxo de Caixa</li>
        </ul>
        <a href="https://app.minhaconfeitaria.com/register" class="btn btn-outline plan-btn">Entrar de graça</a>
      </div>
      <div class="plan feat reveal">
        <div class="plan-badge">⭐ Mais Popular — 2 Meses Grátis</div>
        <div class="plan-cat">Plano PRO ANUAL</div>
        <div class="plan-sub">Seu negócio nos trilhos</div>
        <div class="plan-price-row"><span class="p-cur">R$</span><span class="p-amt">199</span><span style="font-size:.9rem;color:rgba(255,255,255,.45);align-self:flex-end;margin-bottom:9px">/ano</span></div>
        <div class="plan-per">equivale a R$ 16,58/mês · economia de 2 meses</div>
        <div class="plan-div"></div>
        <ul class="plan-feats">
          <li><span class="ck-y">✓</span> Tudo do Plano Gratuito</li>
          <li><span class="ck-y">✓</span> Gerenciamento de Pedidos</li>
          <li><span class="ck-y">✓</span> Cadastro de Clientes</li>
          <li><span class="ck-y">✓</span> Fluxo de Caixa Automático</li>
          <li><span class="ck-y">✓</span> PDF de Orçamentos e Pedidos</li>
          <li><span class="ck-y">✓</span> Impressão Térmica (80mm)</li>
          <li><span class="ck-y">✓</span> Envio por WhatsApp</li>
          <li><span class="ck-y">✓</span> Relatórios completos</li>
        </ul>
        <a href="https://pay.hotmart.com/C6446898J?off=jygntvx0" class="btn btn-grad plan-btn">Assinar Agora →</a>
      </div>
      <div class="plan reveal">
        <div class="plan-cat">Plano PRO</div>
        <div class="plan-sub">Seu negócio nos trilhos</div>
        <div class="plan-price-row"><span class="p-cur">R$</span><span class="p-amt">19</span><span class="p-dec">,90</span></div>
        <div class="plan-per">/mês · cancele a qualquer hora</div>
        <div class="plan-div"></div>
        <ul class="plan-feats">
          <li><span class="ck-y">✓</span> Tudo do Plano Gratuito</li>
          <li><span class="ck-y">✓</span> Gerenciamento de Pedidos</li>
          <li><span class="ck-y">✓</span> Cadastro de Clientes</li>
          <li><span class="ck-y">✓</span> Fluxo de Caixa Automático</li>
          <li><span class="ck-y">✓</span> PDF de Orçamentos e Pedidos</li>
          <li><span class="ck-y">✓</span> Impressão Térmica (80mm)</li>
          <li><span class="ck-y">✓</span> Envio por WhatsApp</li>
          <li><span class="ck-y">✓</span> Relatórios completos</li>
        </ul>
        <a href="https://pay.hotmart.com/C6446898J?off=v1y08b6j&hidePix=1" class="btn btn-grad plan-btn">Assinar Agora →</a>
      </div>
    </div>

    <div class="guarantee-strip reveal">
      <div class="g-item"><div class="g-icon">🛡️</div><div><strong>Garantia de 7 dias</strong><span>Reembolso total, sem burocracia</span></div></div>
      <div class="g-item"><div class="g-icon">🆓</div><div><strong>14 dias grátis no PRO</strong><span>Sem cartão de crédito</span></div></div>
      <div class="g-item"><div class="g-icon">🔒</div><div><strong>Backups diários</strong><span>Seus dados sempre seguros</span></div></div>
      <div class="g-item"><div class="g-icon">↩️</div><div><strong>Sem compromisso</strong><span>Cancele quando quiser</span></div></div>
    </div>
  </div>
</section>

<section class="section" id="pagamento">
  <div class="container">
    <div class="sec-head reveal" style="text-align:center;margin-bottom:40px">
      <div class="tag" style="background:#DCFCE7;color:var(--green)">Pagamento</div>
      <h2>Formas de pagamento</h2>
      <p style="max-width:400px;margin:10px auto 0">Processado pela Hotmart — uma das maiores plataformas do Brasil.</p>
    </div>
    <div class="payment-grid reveal">
      <div class="pay-card">
        <div class="pay-icon">💳</div>
        <strong>Cartão de Crédito</strong>
        <span>Acesso imediato após confirmação</span>
      </div>
      <div class="pay-card">
        <div class="pay-icon">🏦</div>
        <strong>Débito Bancário</strong>
        <span>Acesso imediato após confirmação</span>
      </div>
      <div class="pay-card">
        <div class="pay-icon">📄</div>
        <strong>Boleto Bancário</strong>
        <span>Acesso em até 3 dias úteis após pagamento</span>
      </div>
    </div>
  </div>
</section>

<section class="section s-tint" id="faq">
  <div class="container">
    <div class="sec-head reveal" style="text-align:center;margin-bottom:40px">
      <div class="tag" style="background:#FEF3C7;color:#92400E">Dúvidas</div>
      <h2>Perguntas Frequentes</h2>
    </div>
    <div class="faq-list">
      <div class="faq-item"><button class="faq-q">Como funciona o período de teste de 14 dias? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">Ao se cadastrar, você tem acesso completo ao Plano PRO por 14 dias — sem precisar informar cartão de crédito. Após o período, sua conta migra automaticamente para o Plano Gratuito.</div></div></div>
      <div class="faq-item"><button class="faq-q">Preciso de cartão de crédito para me cadastrar? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">Não! O cadastro e o período de teste são completamente gratuitos e não exigem nenhum dado de pagamento. Você só informa cartão no momento em que decidir assinar o plano PRO.</div></div></div>
      <div class="faq-item"><button class="faq-q">Quais são as formas de pagamento? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">O pagamento é processado pela <strong>Hotmart</strong>. Aceitamos: Cartão de Crédito (acesso imediato), Débito Bancário (acesso imediato) e Boleto Bancário (acesso em até 3 dias úteis).</div></div></div>
      <div class="faq-item"><button class="faq-q">E se eu não gostar? Tenho garantia? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">Sim! Além dos 14 dias de teste grátis, após assinar você tem <strong>7 dias de garantia</strong>. Se não gostar, solicite reembolso — sem burocracia. 100% do valor pago.</div></div></div>
      <div class="faq-item"><button class="faq-q">O que acontece se eu não renovar o plano? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">Sua conta migra automaticamente para o Plano Gratuito. Você <strong>não perde o acesso nem seus dados</strong> — ingredientes, receitas e orçamentos ficam acessíveis.</div></div></div>
      <div class="faq-item"><button class="faq-q">O sistema funciona no celular? <span class="faq-icon">+</span></button><div class="faq-ans"><div class="faq-ans-in">Sim! O sistema é 100% online e funciona em qualquer dispositivo com navegador. Recomendamos o Google Chrome para melhor desempenho.</div></div></div>
    </div>
  </div>
</section>

<div class="cta-band">
  <div class="cta-glow"></div>
  <div class="container" style="position:relative;z-index:2">
    <div class="tag" style="background:rgba(245,197,0,.15);color:var(--yellow)">Comece agora</div>
    <h2 style="color:#fff;margin-bottom:12px">Pronta para começar?</h2>
    <p style="max-width:420px;margin:0 auto 28px">14 dias no PRO grátis, sem cartão. Se crescer, o sistema já está lá.</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:26px">
      <a href="https://app.minhaconfeitaria.com/register" class="btn btn-grad btn-lg">Testar Grátis por 14 dias →</a>
      <a href="/funcionalidades" class="btn btn-ghost btn-lg">Ver funcionalidades</a>
    </div>
    <div class="trust-row" style="justify-content:center">
      <div class="trust-it"><span class="trust-dot"></span>Sem cartão de crédito</div>
      <div class="trust-it"><span class="trust-dot"></span>Plano gratuito permanente</div>
      <div class="trust-it"><span class="trust-dot"></span>Garantia de 7 dias</div>
    </div>
  </div>
</div>
</BaseLayout>

<style>
.page-hero { background: var(--dark); padding: 140px 0 80px; position: relative; overflow: hidden; text-align: center; }
.page-hero-glow { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 700px; height: 400px; background: radial-gradient(ellipse, rgba(124, 58, 237, 0.28) 0%, transparent 70%); pointer-events: none; }
.page-hero h1 { color: #fff; margin-bottom: 14px; }
.page-hero p { color: rgba(255, 255, 255, 0.65); max-width: 520px; margin: 0 auto 26px; font-size: 1.1rem; }
.hero-breadcrumb { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 18px; font-size: 0.85rem; color: rgba(255, 255, 255, 0.45); }
.hero-breadcrumb a { color: rgba(255, 255, 255, 0.45); transition: color 0.2s; }
.hero-breadcrumb a:hover { color: var(--yellow); }
.sec-head { text-align: center; margin-bottom: 52px; }
.pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; align-items: start; }
.plan { background: #fff; border-radius: 20px; padding: 34px 26px; border: 1.5px solid var(--border); position: relative; transition: all 0.25s; }
.plan:hover { transform: translateY(-4px); box-shadow: var(--shadowlg); }
.plan.feat { background: var(--dark); border-color: var(--purple); box-shadow: 0 0 0 3px var(--purple), var(--shadowlg); transform: scale(1.03); }
.plan.feat:hover { transform: scale(1.03) translateY(-4px); }
.plan-badge { position: absolute; top: -13px; left: 50%; transform: translateX(-50%); background: var(--grad); color: #fff; padding: 4px 15px; border-radius: 50px; font-size: 0.76rem; font-weight: 800; white-space: nowrap; }
.plan-cat { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 5px; }
.feat .plan-cat { color: rgba(255, 255, 255, 0.55); }
.plan-sub { font-size: 0.95rem; font-weight: 700; margin-bottom: 18px; }
.feat .plan-sub { color: #fff; }
.plan-price-row { display: flex; align-items: flex-start; gap: 3px; margin-bottom: 4px; }
.p-cur { font-size: 1.1rem; font-weight: 700; line-height: 2.1; }
.feat .p-cur { color: #fff; }
.p-amt { font-family: 'Playfair Display', serif; font-size: 3.8rem; font-weight: 900; line-height: 1; }
.feat .p-amt { color: #fff; }
.p-free { font-family: 'Playfair Display', serif; font-size: 3.4rem; font-weight: 900; color: var(--green); }
.p-dec { font-size: 1.15rem; font-weight: 700; line-height: 2.6; }
.plan-per { font-size: 0.82rem; color: var(--muted); margin-bottom: 22px; }
.feat .plan-per { color: rgba(255, 255, 255, 0.48); }
.plan-div { height: 1px; background: var(--border); margin: 18px 0; }
.feat .plan-div { background: rgba(255, 255, 255, 0.13); }
.plan-feats { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 26px; }
.plan-feats li { display: flex; align-items: center; gap: 9px; font-size: 0.88rem; font-weight: 500; }
.feat .plan-feats li { color: rgba(255, 255, 255, 0.83); }
.ck-y { color: var(--green); }
.ck-n { color: #ccc; }
.plan-btn { width: 100%; text-align: center; display: block; }
.guarantee-strip { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; margin-top: 40px; padding: 28px; background: #fff; border-radius: var(--r); border: 1.5px solid var(--border); }
.g-item { display: flex; align-items: center; gap: 12px; }
.g-icon { font-size: 1.8rem; }
.g-item strong { display: block; font-size: 0.9rem; font-weight: 700; }
.g-item span { font-size: 0.8rem; color: var(--muted); }
.payment-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.pay-card { background: #fff; border-radius: 12px; padding: 24px 22px; border: 1.5px solid var(--border); text-align: center; transition: all 0.2s; }
.pay-card:hover { border-color: var(--purple); box-shadow: var(--shadow); }
.pay-icon { font-size: 2rem; margin-bottom: 10px; }
.pay-card strong { display: block; font-size: 0.95rem; font-weight: 700; margin-bottom: 4px; }
.pay-card span { font-size: 0.82rem; color: var(--muted); }
.faq-list { max-width: 740px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
.faq-item { background: #fff; border-radius: 11px; border: 1.5px solid var(--border); overflow: hidden; transition: border-color 0.2s; }
.faq-item.open { border-color: var(--purple); }
.faq-q { width: 100%; background: none; border: none; padding: 18px 22px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; text-align: left; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.97rem; font-weight: 700; color: var(--dark); }
.faq-icon { width: 26px; height: 26px; border-radius: 50%; background: var(--cream2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.25s; color: var(--purple); font-size: 1.1rem; }
.faq-item.open .faq-icon { transform: rotate(45deg); background: var(--purple); color: #fff; }
.faq-ans { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
.faq-ans-in { padding: 0 22px 18px; font-size: 0.92rem; }
.cta-band { background: var(--dark); padding: 80px 0; position: relative; overflow: hidden; text-align: center; }
.cta-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 300px; background: radial-gradient(ellipse, rgba(124, 58, 237, 0.3) 0%, transparent 70%); pointer-events: none; }
.cta-band h2 { color: #fff; margin-bottom: 12px; }
.cta-band p { color: rgba(255, 255, 255, 0.62); max-width: 440px; margin: 0 auto 28px; }
.reveal { opacity: 0; transform: translateY(22px); transition: all 0.6s ease; }
.reveal.vis { opacity: 1; transform: none; }

@media (max-width: 900px) {
  .pricing-grid, .payment-grid { grid-template-columns: 1fr; }
  .plan.feat { transform: none; }
  .guarantee-strip { gap: 24px; }
}
</style>

<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => nav.classList.toggle('sc', scrollY > 40));

document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item')!;
    const ans = item.querySelector('.faq-ans') as HTMLElement;
    const open = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => {
      i.classList.remove('open');
      (i.querySelector('.faq-ans') as HTMLElement).style.maxHeight = '';
    });
    if (!open) {
      item.classList.add('open');
      ans.style.maxHeight = ans.scrollHeight + 'px';
    }
  });
});

const rv = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      (e.target as HTMLElement).classList.add('vis');
      rv.unobserve(e.target);
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.reveal').forEach(el => rv.observe(el));
</script>
