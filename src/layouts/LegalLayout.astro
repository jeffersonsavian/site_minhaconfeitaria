---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  image?: string;
}

const { title, description, canonical, image } = Astro.props;
---

<BaseLayout title={title} description={description} canonical={canonical} image={image}>
  <div class="legal-container">
    <slot />
  </div>
</BaseLayout>

<!-- Páginas legais têm fundo claro: o nav precisa nascer no estado sólido
     (senão os links brancos ficam invisíveis no topo). Só afeta páginas que usam este layout. -->
<style is:global>
#nav {
  background: rgba(255, 249, 242, 0.93);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 1px 24px rgba(28, 10, 0, 0.07);
}
#nav .nav-links a,
#nav .nav-login {
  color: var(--dark);
}
#nav .nav-login {
  border-color: var(--border);
}
</style>

<style>
.legal-container {
  max-width: 760px;
  margin: 120px auto 80px;
  padding: 0 28px;
}

.legal-container h1 {
  margin-bottom: 32px;
  margin-top: 40px;
}

.legal-container h1:first-child {
  margin-top: 0;
}

.legal-container h2 {
  margin-top: 28px;
  margin-bottom: 14px;
  font-size: 1.4rem;
}

.legal-container p {
  margin-bottom: 18px;
}

.legal-container strong {
  font-weight: 700;
  color: var(--dark);
}
</style>
