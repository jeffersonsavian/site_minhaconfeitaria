# ==========================================================================
#  .htaccess — Minha Confeitaria (site estático)
#  Compatível com OpenLiteSpeed (RewriteRule) e LiteSpeed Enterprise.
#  Vai para a raiz servida (webroot = /dist).
#
#  ATENÇÃO (OpenLiteSpeed): só é lido se o vhost tiver
#    Rewrite > Enable Rewrite = Yes  e  Auto Load from .htaccess = Yes.
#  O OpenLiteSpeed NÃO entende ErrorDocument nem "Redirect 301" via .htaccess
#  — por isso a 404 é definida no vhost e os redirects usam RewriteRule.
# ==========================================================================

# --- Página de erro 404 (LiteSpeed Enterprise lê isto; OLS ignora) --------
# No OpenLiteSpeed, configure a 404 no vhost:
#   Virtual Host > General > Customized Error Pages > 404 = /404.html
ErrorDocument 404 /404.html


# --- Redirects 301 (URLs antigas -> páginas novas) ------------------------
# Formato RewriteRule (funciona no OpenLiteSpeed). Uma linha por URL.
# Exemplos (comentados — descomente/edite):
<IfModule mod_rewrite.c>
  RewriteEngine On

  # RewriteRule ^pagina-antiga/?$        /precos          [R=301,L]
  # RewriteRule ^blog/post-velho/?$      /funcionalidades [R=301,L]
  # RewriteRule ^promo/?$                /precos          [R=301,L]

  # --- Consolidação de host (opcional): força https + sem www ------------
  # RewriteCond %{HTTPS} off [OR]
  # RewriteCond %{HTTP_HOST} ^www\. [NC]
  # RewriteRule ^ https://minhaconfeitaria.com.br%{REQUEST_URI} [L,R=301]
</IfModule>
